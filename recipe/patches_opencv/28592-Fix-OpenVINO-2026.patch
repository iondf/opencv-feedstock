From dae6dcd8c2c259738c491a60cdf8e5a76f31c3ab Mon Sep 17 00:00:00 2001
From: AdityaMishra3000 <mr.ba8man@gmail.com>
Date: Tue, 3 Mar 2026 00:47:56 +0530
Subject: [PATCH] DNN: Fix OpenVINO 2026 build break caused by
 ov::Tensor::data() returning const void*

---
 modules/dnn/src/op_inf_engine.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/modules/dnn/src/op_inf_engine.cpp b/modules/dnn/src/op_inf_engine.cpp
index c95075c855..bc7e5ddc57 100644
--- a/modules/dnn/src/op_inf_engine.cpp
+++ b/modules/dnn/src/op_inf_engine.cpp
@@ -53,7 +53,7 @@ Mat infEngineBlobToMat(const ov::Tensor& blob)
         default:
             CV_Error(Error::StsNotImplemented, "Unsupported blob precision");
     }
-    return Mat(size, type, blob.data());
+    return Mat(size, type, const_cast<void*>(blob.data()));
 }
 
 void infEngineBlobsToMats(const ov::TensorVector& blobs,
-- 
2.52.0

